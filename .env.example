# Epiphany configuration. Copy to `.env` for local use; never commit real secrets.
# Phase 0 requires no configuration. These are illustrative for later phases:

# EPIPHANY_BIND_ADDR=127.0.0.1:8080
# EPIPHANY_DATA_DIR=./data
# EPIPHANY_LOG=info

# Run the server in deterministic mode (fixed clock/RNG/seed) for tests:
# EPIPHANY_DETERMINISTIC=1
# EPIPHANY_SEED=20200101
